{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "extends": ["ultracite/core", "ultracite/react"],
  "files": {
    "ignoreUnknown": false,
    "includes": [
      "**/src/**/*",
      "**/.vscode/**/*",
      "**/index.html",
      "!**/reportWebVitals.ts",
      "!**/src/index.css",
      "!**/src/components/ui/*.tsx"
    ]
  }
}
